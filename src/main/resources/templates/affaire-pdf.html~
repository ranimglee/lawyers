<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>وثيقة رسمية - الهيئة الوطنية للمحامين</title>

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Noto Naskh Arabic', serif;
            background: #eef1f5;
            padding: 2rem;
            line-height: 1.5;
            color: #1e2d3a;
            min-height: 100vh;
            unicode-bidi: embed;

            direction: rtl;
        }

        p, span {
            direction: rtl;
            unicode-bidi: embed;
        }

        .document {
            width: 210mm;
            min-height: 297mm;
            margin: 0 auto;
            background: #fff;
            padding: 20mm 25mm;
            border: 1px solid #e0e4e9;
        }
        .header-table {
            width: 100%;
            margin-bottom: 20px;
            border-bottom: 2px solid #1e2d3a;
            padding-bottom: 10px;
        }

        .header-text {
            text-align: right;
            vertical-align: middle;
        }

        .header-logo {
            text-align: left;
            width: 150px;
        }

        .header-logo img {
            max-width: 120px;
        }

        /* Use block layouts instead of flex */
        .header { margin-bottom: 2rem; border-bottom: 2px solid #1e2d3a; padding-bottom: 1rem; }
        .header img { float: left; max-width: 140px; height: auto; }
        .org-name { font-size: 1.5rem; font-weight: 700; }
        .branch { font-size: 1.1rem; font-weight: 600; margin-top: 0.1rem; }

        .section { margin-bottom: 1.2rem; }
        .section p { font-size: 1.05rem; text-align: right; }
        .field {
            display: inline;
            padding: 0 4px;
            color: #000;
            font-weight: bold;
        }
        .field-long { min-width: 18rem; }
        .field-date { min-width: 8rem; letter-spacing: 0.15em; }

        .greeting {
            background: #f4f6f8;
            border-right: 4px solid #2c5282;
            padding: 12px;
            margin: 15px 0;
            font-size: 14px;
        }
        .signature-block {
            margin-top: 40px;
            text-align: center;
        }

        .signature-line {
            display: inline-block;
            width: 150px;
            border-bottom: 1px solid #000;
            margin-top: 10px;
        }
        .witness-block { background: #f8f9fb; border: 1px solid #e4e8ec; border-right: 4px solid #2d6a4f; padding: 1.5rem 1.75rem; margin-top: 2rem; border-radius: 0 6px 6px 0; }

        @media print {
            @page { size: A4; margin: 0; }
            body { background: #fff; padding: 0; margin: 0; }
            .document { width: 210mm; min-height: 297mm; margin: 0; padding: 20mm 25mm; border: none; }
        }
    </style>
</head>
<body>

<div class="document">

    <header class="header">
        <table class="header-table">
            <tr>
                <td class="header-text">
                    <div class="org-name" th:text="${orgName}"></div>
                    <div class="branch" th:text="${branch}"></div>
                </td>
                <td class="header-logo">
                    <img src="logo-onan.jpg" alt="شعار الهيئة"/>
                </td>
            </tr>
        </table>
    </header>

    <section class="section">
        <p>
            <span th:text="${dateLabel}"></span>
            <span class="field-date" th:text="${date}"></span>
        </p>
    </section>

    <section class="section">
        <p>
            <span th:text="${lawyerLabel}"></span>
            <strong><span class="field field-long" th:text="${avocatNom}"></span></strong><br/>

            <span th:text="${registrationLabel}"></span>
            <span class="field" th:text="${avocatId}"></span>
            <span th:text="${traineeLawyer}"></span>
        </p>
    </section>

    <section class="section">
        <p>
            <span th:text="${addressLabel}"></span>
            <span class="field field-long" th:text="${avocatAdresse}"></span>
        </p>
    </section>

    <section class="section greeting">
        <p th:text="${greeting}"></p>
    </section>



    <section class="section">
        <p>
            <span th:text="${forLabel}"></span>
            <strong><span class="field field-long" th:text="${affaireNomAccuse}"></span></strong><br/>

            <span th:text="${againstLabel}"></span>
            <span class="field field-long"></span>
        </p>
    </section>

    <section class="section">
        <p>
            <span th:text="${caseLabel}"></span>
            <span class="field" th:text="${affaireNumero}"></span><br/>

            <span th:text="${sessionLabel}"></span>
            <span class="field field-long" th:text="${#temporals.format(dateTribunal, 'dd/MM/yyyy')}"></span>
        </p>
    </section>

    <section class="section">
        <p th:text="${closing}"></p>
    </section>

    <div class="signature-block">
        <p><strong th:text="${presidentLabel}"></strong></p>
        <p>
            <span th:text="${signatureLabel}"></span>
            <span class="signature-line"></span>
        </p>
    </div>

    <div class="witness-block">
        <p>
            <span th:text="${witnessPrefix}"></span>
            <span class="field field-long" th:text="${avocatNom}"></span>
            <span th:text="${traineeLawyer}"></span><br/>

            <span th:text="${receivedLabel}"></span>
            <span class="field-date" th:text="${date}"></span><br/>

            <span th:text="${underNumberLabel}"></span>
            <span class="field" th:text="${affaireNumero}"></span>
            <span th:text="${onBehalfLabel}"></span>
            <span class="field" th:text="${affaireNomAccuse}"></span><br/>

            <span th:text="${caseNumberLabel}"></span>
            <span class="field" th:text="${affaireNumero}"></span><br/>

            <span th:text="${sessionDayLabel}"></span>
            <span class="field" th:text="${#temporals.format(dateTribunal, 'dd/MM/yyyy')}"></span><br/>

            <span th:text="${courtLabel}"></span>
            <span class="field field-long" th:text="${affaireType}"></span>
        </p>

        <p style="margin-top: 1rem;">
            <span th:text="${signatureLabel}"></span>
            <span class="signature-line"></span>
        </p>
    </div>

</div>

</body>
</html>